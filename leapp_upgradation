dnf install leapp-upgrade -y
dnf install leapp-upgrade-el8toel9-fapolicyd -y
dnf install vdo -y
vi /etc/leapp/files/leapp_upgrade_repositories.repo
leapp answer --section check_vdo.confirm=True
cat /var/log/leapp/answerfile
less /var/log/leapp/leapp-report.txt
leapp preupgrade --no-rhsm
leapp upgrade --no-rhsm
reboot
