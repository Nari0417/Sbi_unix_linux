---
- name: Remove old kernels
  hosts: all
  become: yes

  tasks:

    - name: Get running kernel
      command: uname -r
      register: running_kernel

    - name: Get kernels to remove
      shell: |
        rpm -q kernel-core | grep -v "{{ running_kernel.stdout }}" | sort -V | head -n -1
      register: kernels_to_remove

    - name: Remove old kernels
      shell: yum -y remove {{ item }}
      with_items: "{{ kernels_to_remove.stdout_lines }}"
      when: kernels_to_remove.stdout_lines | length > 0
