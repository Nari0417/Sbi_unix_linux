---
- name: Remove old kernels
  hosts: all
  become: yes

  tasks:

    - name: Get running kernel
      command: uname -r
      register: running_kernel

    - name: Show running kernel
      debug:
        msg: "Running kernel: {{ running_kernel.stdout }}"

    - name: Get kernels to remove
      shell: |
        rpm -q kernel-core | grep -v "{{ running_kernel.stdout }}" | sort -V | head -n -1
      register: kernels_to_remove

    - name: Show kernels identified for removal
      debug:
        var: kernels_to_remove.stdout_lines

    - name: Remove old kernels
      shell: yum -y remove {{ item }}
      with_items: "{{ kernels_to_remove.stdout_lines }}"
      register: remove_result
      when: kernels_to_remove.stdout_lines | length > 0

    - name: Show removal output
      debug:
        var: remove_result.results
      when: kernels_to_remove.stdout_lines | length > 0

    - name: Show remaining kernels
      shell: rpm -q kernel-core | sort -V
      register: remaining_kernels

    - name: Display remaining kernels
      debug:
        var: remaining_kernels.stdout_lines
